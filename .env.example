DEBUG=True
SECRET_KEY=cambiar-en-produccion
DATABASE_URL=postgis://miraki_user:miraki_pass@db:5432/miraki_db
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
REDIS_URL=redis://redis:6379/0

# Variables que usa la imagen postgis/postgis para inicializar la base de datos
# la primera vez. Deben coincidir con las credenciales usadas en DATABASE_URL.
POSTGRES_DB=miraki_db
POSTGRES_USER=miraki_user
POSTGRES_PASSWORD=miraki_pass

# Opcional: solo si corres Django nativo en Windows (fuera de Docker) y
# necesitas apuntar a las DLL de GEOS/GDAL de tu instalación local de
# PostgreSQL+PostGIS. En Docker no se definen.
# GDAL_LIBRARY_PATH=C:\Program Files\PostgreSQL\17\bin\libgdal-35.dll
# GEOS_LIBRARY_PATH=C:\Program Files\PostgreSQL\17\bin\libgeos_c.dll
